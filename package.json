{
  "name": "nusaicons",
  "version": "1.0.3",
  "description": "Pustaka ikon SVG open-source premium untuk developer Indonesia. 38+ ikon berkualitas tinggi, mendukung currentColor & Tailwind CSS.",
  "keywords": [
    "icons",
    "svg",
    "icon-library",
    "css-icons",
    "nusaicons",
    "indonesia",
    "tailwind",
    "currentcolor",
    "open-source",
    "ui",
    "frontend"
  ],
  "author": {
    "name": "Amrunamv",
    "url": "https://github.com/amrunamv"
  },
  "license": "MIT",
  "homepage": "https://amrunamv.github.io/nusaicon/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amrunamv/nusaicon.git"
  },
  "bugs": {
    "url": "https://github.com/amrunamv/nusaicon/issues"
  },
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    },
    "./css": "./nusaicons.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "nusaicons.css",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node build.js",
    "prepublishOnly": "npm run build"
  },
  "sideEffects": [
    "*.css"
  ],
  "engines": {
    "node": ">=14.0.0"
  }
}
